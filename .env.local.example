# ==============================================
# ECL Academy - Variables de entorno
# Copia este archivo a .env.local y completa los valores
# ==============================================

# URL base del sitio (usada en callbacks de Stripe)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ----- Autenticación -----
# Clave para firmar los JWT de sesión. Genera una con:
#   openssl rand -base64 32
AUTH_SECRET=

# ----- Stripe -----
# Obtén tus llaves en https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxx
# Secreto del webhook (stripe listen / dashboard de webhooks)
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxx

# ----- evolCampus (EvolMind) - LMS / matrículas -----
# Autenticación por JWT (POST /v1/token con clientid + key).
# Obtén clientid y key en el panel de tu cuenta evolCampus.
EVOLMIND_API_URL=https://api.evolcampus.com/api
EVOLMIND_CLIENT_ID=
EVOLMIND_API_KEY=

# ----- Admin -----
# Token para endpoints administrativos (reintento de sync, test de Evolmind).
# Genera uno con: openssl rand -hex 24
ADMIN_TOKEN=
