# ==============================================
# ECL Academy - Variables de entorno
# Copia este archivo a .env.local y completa los valores
# ==============================================

# URL base del sitio (usada en callbacks de Stripe)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ----- Autenticación -----
# Clave para firmar los JWT de sesión. Genera una con:
#   openssl rand -base64 32
AUTH_SECRET=

# ----- Stripe -----
# Obtén tus llaves en https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxx
# Secreto del webhook (stripe listen / dashboard de webhooks)
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxx

# ----- Evolmind / evolCampus (LMS - matrículas) -----
# Datos que debes obtener del panel de tu cuenta evolCampus:
EVOLMIND_API_URL=https://www.evolcampus.com/api/
EVOLMIND_API_KEY=tu_clave_privada
EVOLMIND_ACCOUNT_ID=

# Formato y nombres de parámetros (ajusta según la doc de tu instancia).
# Por defecto: form-urlencoded con action=subscribe.
EVOLMIND_REQUEST_FORMAT=form          # "form" | "json"
EVOLMIND_KEY_PARAM=key                # nombre del parámetro de la clave
EVOLMIND_ACTION_PARAM=action          # nombre del parámetro de acción
EVOLMIND_ENROLL_ACTION=subscribe      # valor de la acción de matrícula
EVOLMIND_FIELD_EMAIL=email            # campo email del alumno
EVOLMIND_FIELD_NAME=name              # campo nombre del alumno
EVOLMIND_FIELD_COURSE=course          # campo curso (usa Course.evolmindCourseId)

# ----- Admin -----
# Token para endpoints administrativos (reintento de sync, test de Evolmind).
# Genera uno con: openssl rand -hex 24
ADMIN_TOKEN=
