# Postgres local vía Homebrew (usuario del sistema, sin contraseña):
DATABASE_URL="postgresql://TU_USUARIO@localhost:5432/ecl_academy?schema=public"

# Ejemplo con usuario/contraseña:
# DATABASE_URL="postgresql://postgres:password@localhost:5432/ecl_academy?schema=public"
