// Prisma schema para ECL Academy
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

/// Usuario / estudiante
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  password  String // hash bcrypt
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  carts       Cart[]
  orders      Order[]
  enrollments Enrollment[]

  @@map("users")
}

/// Curso / producto que se puede comprar
model Course {
  id               Int      @id @default(autoincrement())
  slug             String   @unique
  title            String
  category         String
  icon             String
  shortDescription String
  description      String
  price            Int // precio en USD (dólares enteros)
  originalPrice    Int
  rating           Float    @default(0)
  reviews          Int      @default(0)
  students         Int      @default(0)
  weeks            Int      @default(0)
  lessons          Int      @default(0)
  badge            String? // "bestseller" | "new" | "popular"
  // ----- Vínculo con evolCampus (fuente de verdad del catálogo) -----
  evolmindCourseId Int? // id del curso en evolCampus (getCourses)
  evolmindGroupId  Int? // id del grupo en evolCampus (newEnrollment[groupid])
  evolmindSynced   Boolean  @default(false)
  evolmindError    String?
  subjects         Json? // asignaturas del curso en evolCampus
  // ----- Comercio / presentación (gestionado en nuestra plataforma) -----
  whatYouLearn     String[] @default([]) // "Lo que aprenderás"
  requirements     String[] @default([]) // requisitos
  audience         String[] @default([]) // "¿Para quién es?"
  published        Boolean  @default(false) // visible en la tienda
  active           Boolean  @default(true) // activo en evolCampus (matriculable)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  cartItems   CartItem[]
  orderItems  OrderItem[]
  enrollments Enrollment[]

  @@map("courses")
}

/// Carrito de compras. Anónimo (cookie) o asociado a un usuario.
model Cart {
  id        String     @id @default(uuid())
  userId    String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]

  @@map("carts")
}

/// Ítem dentro de un carrito. Un curso solo puede estar una vez por carrito.
model CartItem {
  id        Int      @id @default(autoincrement())
  cartId    String
  courseId  Int
  createdAt DateTime @default(now())

  cart   Cart   @relation(fields: [cartId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([cartId, courseId])
  @@map("cart_items")
}

/// Orden de compra. Se crea al iniciar el checkout (PENDING) y se
/// confirma vía webhook de Stripe (PAID).
model Order {
  id              String      @id @default(uuid())
  userId          String?
  email           String
  status          OrderStatus @default(PENDING)
  total           Int // total en USD
  currency        String      @default("usd")
  stripeSessionId String?     @unique
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user        User?        @relation(fields: [userId], references: [id])
  items       OrderItem[]
  enrollments Enrollment[]

  @@map("orders")
}

/// Ítem de una orden (snapshot del precio al momento de la compra).
model OrderItem {
  id       Int    @id @default(autoincrement())
  orderId  String
  courseId Int
  title    String
  price    Int

  order  Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id])

  @@map("order_items")
}

/// Matrícula de un estudiante en un curso (tras pago exitoso).
model Enrollment {
  id                   String    @id @default(uuid())
  userId               String?
  courseId             Int
  orderId              String?
  email                String
  studentName          String?
  status               String    @default("active")
  // ----- Sincronización con evolCampus -----
  evolmindEnrollmentId String?
  evolmindUserId       Int?
  evolmindSynced       Boolean   @default(false)
  evolmindError        String?
  evolmindSyncedAt     DateTime?
  syncAttempts         Int       @default(0)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt @default(now())

  user   User?  @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])
  order  Order? @relation(fields: [orderId], references: [id])

  @@unique([userId, courseId])
  @@map("enrollments")
}
